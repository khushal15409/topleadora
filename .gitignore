# ------------------------------
.DS_Store
Thumbs.db

# ------------------------------
# IDE / Editors
# ------------------------------
/.idea
/.vscode
/.fleet
/.zed

# ------------------------------
# Environment & secrets
# ------------------------------
.env
.env.*
!.env.example
auth.json

# ------------------------------
# Logs / temp
# ------------------------------
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
laravel.log

# ------------------------------
# PHP / Laravel dependencies & cache
# ------------------------------
/vendor
/bootstrap/cache/*
!/bootstrap/cache/.gitignore

# Keep framework directories, ignore generated contents only
/storage/*.key
/storage/debugbar
/storage/logs/*
!/storage/logs/.gitignore
/storage/framework/cache/*
!/storage/framework/cache/.gitignore
/storage/framework/cache/data/*
!/storage/framework/cache/data/.gitignore
/storage/framework/sessions/*
!/storage/framework/sessions/.gitignore
/storage/framework/views/*
!/storage/framework/views/.gitignore
/storage/framework/testing/*
!/storage/framework/testing/.gitignore
/storage/app/public

# Public symlink
/public/storage

# ------------------------------
# Node / frontend generated
# ------------------------------
/node_modules
/public/hot
/public/build/*
!/public/build/.gitignore
/public/assets/build
/public/assets/*.map
/public/assets/js/*.map
/public/assets/css/*.map
/dist
/build
*.map
.cache/
.parcel-cache/
.next/
.nuxt/
coverage/

# ------------------------------
# Optional local env tools
# ------------------------------
Homestead.json
Homestead.yaml
.phpunit.result.cache
.phpunit.cache
.phpactor.json